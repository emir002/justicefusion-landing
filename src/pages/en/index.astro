<section class="container hero"><div><h1>JusticeFusion — Legal AI assistant for local law and private documents</h1><p>Search laws, regulations, case law and internal documents in natural language.</p><div class="cta"><a class="btn" href="https://justicefusion.cc/" target="_blank" rel="noopener">Access assistant</a><a class="btn ghost" href="/en/whitepaper">Read whitepaper</a></div></div><img src="/images/hero-placeholder.png" alt="JusticeFusion product preview" width="560" height="420"/></section>
<section class="container" id="contact"><h2>Request demo or more information</h2><form action="https://formsubmit.co/justicefusion@gmail.com" method="POST" class="contact"><input type="hidden" name="_captcha" value="false" /><input name="name" required placeholder="Full name"/><input name="email" type="email" required placeholder="Email"/><textarea name="message" required placeholder="Message"></textarea><button class="btn" type="submit">Send message</button></form></section>
