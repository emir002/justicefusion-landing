---
const { lang = "bs", contactId = "contact", switchHref = "/en/", switchLabel = "EN" } = Astro.props;
const bs = lang === "bs";
---
<footer class="site-footer">
  <div class="container footer-grid">
    <img src="/images/graphlab_logo.png" alt="GraphLab logo" class="footer-logo" width="120" height="40" loading="lazy"/>
    <p>© 2026 GraphLab</p>
    <nav aria-label="Footer links" class="footer-links">
      <a href={bs ? "/" : "/en/"}>{bs ? "Početna" : "Home"}</a>
      <a href={bs ? "/whitepaper" : "/en/whitepaper"}>Whitepaper</a>
      <a href={bs ? "/prednosti" : "/en/advantages-over-chatgpt"}>{bs ? "Prednosti" : "Advantages"}</a>
      <a href={`#${contactId}`}>{bs ? "Kontakt" : "Contact"}</a>
      <a href={switchHref}>{switchLabel}</a>
    </nav>
  </div>
</footer>
